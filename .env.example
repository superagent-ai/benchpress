# Copy secrets from your operator env file; do not commit real keys.
# Example: dotenvx run -f ~/.config/secrets/global.env -- npm run bench -- matrix --config config/matrix.example.jsonc

# Which autobrin-flue branch autobrin contenders use when ref is omitted (default: staging)
# AUTOBRIN_FLUE_REF=staging

# Daytona sandbox provisioning (bench daytona run / bench daytona doctor)
# DAYTONA_API_KEY=
# DAYTONA_JWT_TOKEN=
# DAYTONA_ORGANIZATION_ID=
# DAYTONA_API_URL=
# DAYTONA_TARGET=

# Computer use inside Daytona sandboxes (topology A: agent-in-sandbox)
# AUTOBRIN_COMPUTER_USE=daytona
# AUTOBRIN_COMPUTER_USE_BASE_URL=http://127.0.0.1:2280
# CUA_SCREENSHOT_VISION_MODEL=kimi-k2.6

# Agent model provider keys (passed through to autobrin-flue engagements)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=
# GOOGLE_API_KEY=
# GH_TOKEN=
# AUTOBRIN_FLUE_GITHUB_TOKEN=
